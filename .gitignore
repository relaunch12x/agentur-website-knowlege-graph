# Only the website/ folder should be in the repo
# Ignore everything, then whitelist website/

# Ignore all
/*

# Allow gitignore itself
!.gitignore

# Allow website folder
!/website/

# Inside website: standard ignores
website/node_modules/
website/dist/
website/.astro/
website/.env
website/.env.production

# OS files
.DS_Store
Thumbs.db
