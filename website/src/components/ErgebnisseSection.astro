---
---

<section
  class="grain-overlay relative overflow-hidden"
  style="background: var(--color-sand); padding-block: var(--spacing-section);"
>
  <div class="container-wide">
    <!-- Header -->
    <div class="mb-16 max-w-3xl reveal-on-scroll">
      <span class="section-label mb-4 block">Was du bekommst</span>
      <h2 style="color: var(--color-ink);">
        Kein Dokument, das in der Schublade landet. Ein System, das arbeitet.
      </h2>
    </div>

    <!-- Bento Grid -->
    <div class="bento-grid">
      <!-- Card 1: Agile Website (spans 2 cols on lg) -->
      <div class="bento-card bento-card--wide reveal-on-scroll stagger-1">
        <div class="bento-card__visual">
          <div class="terminal">
            <div class="terminal__header">
              <span class="terminal__dot terminal__dot--red"></span>
              <span class="terminal__dot terminal__dot--yellow"></span>
              <span class="terminal__dot terminal__dot--green"></span>
            </div>
            <div class="terminal__body">
              <span class="terminal__prompt">&gt;</span> <span class="terminal__cmd">astro build</span>
              <br />
              <span class="terminal__success">✓</span> <span class="terminal__text">Built in 0.4s</span>
              <br />
              <span class="terminal__prompt">&gt;</span> <span class="terminal__cmd">deploy --production</span>
              <br />
              <span class="terminal__success">✓</span> <span class="terminal__text">Live. Neue Landingpage am selben Tag.</span>
            </div>
          </div>
        </div>
        <div class="bento-card__content">
          <h3>Agile Website</h3>
          <p>
            Eine Astro-Architektur, auf der eine neue Landingpage am selben Tag steht.
            Kein Pagebuilder. Kein Warten.
          </p>
        </div>
        <span class="bento-card__arrow" aria-hidden="true">&rarr;</span>
      </div>

      <!-- Card 2: Knowledge Graph (1 col) -->
      <div class="bento-card reveal-on-scroll stagger-2">
        <div class="bento-card__visual">
          <svg class="network-diagram" viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Edges -->
            <line x1="60" y1="50" x2="140" y2="40" stroke="var(--color-ultraviolett)" stroke-width="1.5" stroke-opacity="0.35" />
            <line x1="60" y1="50" x2="100" y2="120" stroke="var(--color-ultraviolett)" stroke-width="1.5" stroke-opacity="0.35" />
            <line x1="140" y1="40" x2="100" y2="120" stroke="var(--color-ultraviolett)" stroke-width="1.5" stroke-opacity="0.35" />
            <line x1="140" y1="40" x2="170" y2="110" stroke="var(--color-ultraviolett)" stroke-width="1.5" stroke-opacity="0.35" />
            <line x1="100" y1="120" x2="170" y2="110" stroke="var(--color-ultraviolett)" stroke-width="1.5" stroke-opacity="0.25" />
            <!-- Nodes -->
            <circle cx="60" cy="50" r="10" fill="var(--color-ultraviolett)" opacity="0.15" />
            <circle cx="60" cy="50" r="4" fill="var(--color-ultraviolett)" />
            <circle cx="140" cy="40" r="14" fill="var(--color-ultraviolett)" opacity="0.15" />
            <circle cx="140" cy="40" r="5.5" fill="var(--color-ultraviolett)" />
            <circle cx="100" cy="120" r="12" fill="var(--color-ultraviolett)" opacity="0.15" />
            <circle cx="100" cy="120" r="5" fill="var(--color-ultraviolett)" />
            <circle cx="170" cy="110" r="8" fill="var(--color-ultraviolett)" opacity="0.15" />
            <circle cx="170" cy="110" r="3.5" fill="var(--color-ultraviolett)" />
          </svg>
        </div>
        <div class="bento-card__content">
          <h3>Knowledge Graph</h3>
          <p>
            Dein gesamtes validiertes Unternehmenswissen — strukturiert, verbunden, abrufbar.
          </p>
        </div>
        <span class="bento-card__arrow" aria-hidden="true">&rarr;</span>
      </div>

      <!-- Card 3: SEO & Content (1 col) -->
      <div class="bento-card reveal-on-scroll stagger-3">
        <div class="bento-card__visual">
          <div class="bar-chart" aria-hidden="true">
            <div class="bar-chart__bar bar-chart__bar--1"></div>
            <div class="bar-chart__bar bar-chart__bar--2"></div>
            <div class="bar-chart__bar bar-chart__bar--3"></div>
          </div>
        </div>
        <div class="bento-card__content">
          <h3>SEO &amp; Content</h3>
          <p>
            Keyword-Strategie und Content-Plan aus dem Knowledge Graph abgeleitet. Nicht geraten.
          </p>
        </div>
        <span class="bento-card__arrow" aria-hidden="true">&rarr;</span>
      </div>

      <!-- Card 4: Tracking & Loop (spans 2 cols on lg) -->
      <div class="bento-card bento-card--wide reveal-on-scroll stagger-4">
        <div class="bento-card__visual">
          <div class="dashboard">
            <div class="dashboard__metrics">
              <div class="dashboard__metric">
                <span class="dashboard__metric-label">Conversions</span>
                <span class="dashboard__metric-value">+34%</span>
              </div>
              <div class="dashboard__metric">
                <span class="dashboard__metric-label">Bounce Rate</span>
                <span class="dashboard__metric-value">28.1%</span>
              </div>
              <div class="dashboard__metric">
                <span class="dashboard__metric-label">Avg. Position</span>
                <span class="dashboard__metric-value">4.2</span>
              </div>
            </div>
            <div class="dashboard__chart">
              <svg viewBox="0 0 240 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <polyline
                  points="0,50 30,45 60,48 90,35 120,30 150,22 180,18 210,10 240,5"
                  stroke="var(--color-ultraviolett)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                />
                <linearGradient id="chart-fill" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--color-ultraviolett)" stop-opacity="0.15" />
                  <stop offset="100%" stop-color="var(--color-ultraviolett)" stop-opacity="0" />
                </linearGradient>
                <polygon
                  points="0,50 30,45 60,48 90,35 120,30 150,22 180,18 210,10 240,5 240,60 0,60"
                  fill="url(#chart-fill)"
                />
              </svg>
            </div>
          </div>
        </div>
        <div class="bento-card__content">
          <h3>Tracking &amp; Loop</h3>
          <p>
            PostHog, Google Search Console, Conversion-Tracking.
            Jedes Ergebnis fließt zurück ins System.
          </p>
        </div>
        <span class="bento-card__arrow" aria-hidden="true">&rarr;</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* Bento Grid Layout */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2vw, 24px);
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .bento-card--wide {
      grid-column: span 2;
    }
  }

  /* Card Base */
  .bento-card {
    position: relative;
    background: #ffffff;
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: var(--radius-lg);
    padding: clamp(20px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    transition:
      transform var(--duration-normal) var(--ease-smooth),
      box-shadow var(--duration-normal) var(--ease-smooth);
    overflow: hidden;
  }

  .bento-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .bento-card:hover .bento-card__arrow {
    opacity: 1;
    transform: translate(0, 0);
  }

  /* Arrow */
  .bento-card__arrow {
    position: absolute;
    bottom: clamp(16px, 2vw, 24px);
    right: clamp(16px, 2vw, 24px);
    font-size: 1.25rem;
    color: var(--color-ultraviolett);
    opacity: 0;
    transform: translate(-4px, 4px);
    transition:
      opacity var(--duration-normal) var(--ease-smooth),
      transform var(--duration-normal) var(--ease-smooth);
    line-height: 1;
  }

  /* Visual area */
  .bento-card__visual {
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  /* Content */
  .bento-card__content h3 {
    margin-bottom: 8px;
    color: var(--color-ink);
  }

  .bento-card__content p {
    color: var(--color-ink-light);
    font-size: clamp(0.875rem, 0.5vw + 0.5rem, 1rem);
    line-height: 1.6;
    max-width: 48ch;
  }

  /* === Terminal Mockup === */
  .terminal {
    background: var(--color-ink);
    border-radius: var(--radius-md);
    overflow: hidden;
    font-family: var(--font-mono);
    font-size: clamp(0.75rem, 1vw, 0.875rem);
    line-height: 1.7;
  }

  .terminal__header {
    display: flex;
    gap: 6px;
    padding: 10px 14px 0;
  }

  .terminal__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .terminal__dot--red { background: #ff5f57; }
  .terminal__dot--yellow { background: #febc2e; }
  .terminal__dot--green { background: #28c840; }

  .terminal__body {
    padding: 12px 14px 14px;
    color: rgba(245, 240, 232, 0.6);
  }

  .terminal__prompt {
    color: rgba(245, 240, 232, 0.35);
  }

  .terminal__cmd {
    color: var(--color-sand);
  }

  .terminal__success {
    color: #28c840;
  }

  .terminal__text {
    color: rgba(245, 240, 232, 0.6);
  }

  /* === Network Diagram === */
  .network-diagram {
    width: 100%;
    max-width: 200px;
    height: auto;
  }

  /* === Bar Chart === */
  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 100px;
    padding: 8px 0;
  }

  .bar-chart__bar {
    width: 32px;
    border-radius: 4px 4px 0 0;
    background: var(--color-ultraviolett);
  }

  .bar-chart__bar--1 {
    height: 35%;
    opacity: 0.3;
  }

  .bar-chart__bar--2 {
    height: 60%;
    opacity: 0.55;
  }

  .bar-chart__bar--3 {
    height: 90%;
    opacity: 0.85;
  }

  /* === Dashboard Mockup === */
  .dashboard__metrics {
    display: flex;
    gap: clamp(12px, 2vw, 20px);
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .dashboard__metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dashboard__metric-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-ink-light);
  }

  .dashboard__metric-value {
    font-family: var(--font-mono);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 700;
    color: var(--color-ink);
  }

  .dashboard__chart {
    width: 100%;
  }

  .dashboard__chart svg {
    width: 100%;
    height: auto;
  }
</style>
