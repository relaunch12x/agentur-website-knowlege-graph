---
/**
 * GruenderstorySection — Two founders, one story. Interactive tabs.
 * White background for contrast between Sand sections.
 */
import GruenderstoryTabs from "./GruenderstoryTabs.tsx";
---

<section
  class="relative overflow-hidden"
  style="background-color: var(--color-white);"
>
  <div
    class="container-content"
    style="padding-top: clamp(80px, 12vw, 180px); padding-bottom: clamp(80px, 12vw, 180px);"
  >
    <div class="reveal-on-scroll" style="max-width: 800px; margin: 0 auto;">
      <span class="section-label mb-6 block text-center">Die Geschichte</span>

      <h2
        class="mb-4 text-center"
        style="color: var(--color-ink); font-size: clamp(1.875rem, 3vw + 0.5rem, 3rem);"
      >
        Freunde seit der ersten Klasse.
      </h2>
      <p
        class="text-center mb-16"
        style="color: var(--color-ink-light); font-size: clamp(1rem, 1.2vw, 1.125rem); max-width: 520px; margin-inline: auto;"
      >
        Über 30 Jahre Freundschaft. Zwei Wege. Dieselbe Erkenntnis.
      </p>

      <GruenderstoryTabs client:visible />

      <div class="story-conclusion reveal-on-scroll mt-16">
        <div class="conclusion-line"></div>
        <p class="conclusion-text">
          Zwei verschiedene Wege. Dasselbe Ergebnis: <em>Annahmen</em> sind der Grund, warum gute Unternehmen nicht wachsen.
          Also haben wir ein System gebaut, das <em>Fakten</em> von Annahmen trennt — und daraus alles ableitet.
        </p>
        <p class="conclusion-closer">
          Das ist Relaunch12x.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .conclusion-line {
    width: 48px;
    height: 2px;
    background: var(--color-ultraviolett);
    margin: 0 auto clamp(20px, 3vw, 32px);
    opacity: 0.4;
  }

  .conclusion-text {
    font-size: clamp(1.0625rem, 1.3vw, 1.1875rem);
    color: var(--color-ink-light);
    line-height: 1.75;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .conclusion-text em {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-style: italic;
  }

  .conclusion-closer {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ultraviolett);
    letter-spacing: 0.02em;
    text-align: center;
    margin-top: clamp(12px, 2vw, 20px);
  }
</style>
