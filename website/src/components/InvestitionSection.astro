---
/**
 * InvestitionSection — Transparent pricing + ROI argument.
 * Sand background. Two side-by-side spec-sheet cards.
 */

interface Feature {
  text: string;
}

const phase1Features: Feature[] = [
  { text: "Wissens-Audit & Knowledge Graph" },
  { text: "Positionierung & Messaging" },
  { text: "Designsystem & Brand Voice" },
  { text: "Website auf Astro-Architektur" },
  { text: "SEO-Grundstruktur" },
  { text: "Tracking-Setup (PostHog, GSC)" },
];

const phase2Features: Feature[] = [
  { text: "Alles aus Phase 1" },
  { text: "Monatliche Hypothesen & Tests" },
  { text: "Content-Produktion (SEO, GEO)" },
  { text: "AI-gestützte Workflows" },
  { text: "Neue Landingpages am selben Tag" },
  { text: "Quartals-Reviews & Strategie-Updates" },
  { text: "Knowledge Graph wächst mit" },
];
---

<section
  id="investition"
  class="grain-overlay relative overflow-hidden"
  style="background-color: var(--color-sand);"
>
  <div
    class="container-wide relative z-10"
    style="padding-top: clamp(80px, 12vw, 180px); padding-bottom: clamp(80px, 12vw, 180px);"
  >
    <!-- Header -->
    <div class="text-center mb-16 lg:mb-20 reveal-on-scroll">
      <span class="section-label mb-6 block">Investition</span>
      <h2 class="mb-6" style="color: var(--color-ink);">
        Transparent. Kein Kleingedrucktes.
      </h2>
      <p
        class="mx-auto"
        style="max-width: 640px; color: var(--color-ink-light);"
      >
        Du investierst nicht in eine Website. Du investierst in ein Wissenssystem, das 12 Monate lang testet, lernt und wächst.
      </p>
    </div>

    <!-- Cards -->
    <div class="flex flex-col lg:flex-row gap-8 max-w-[960px] mx-auto">

      <!-- Card 1: From 0 to 1 -->
      <div class="pricing-card reveal-on-scroll lg:w-1/2">
        <div class="card-header">
          <h3 class="card-title">From 0 to 1</h3>
          <span class="card-subtitle">Das Fundament</span>
        </div>

        <div class="card-price-area">
          <span class="card-price">Auf Anfrage</span>
        </div>

        <div class="card-divider"></div>

        <ul class="card-features">
          {phase1Features.map((feature) => (
            <li class="card-feature">
              <svg class="feature-check" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 10.5L8.5 14L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{feature.text}</span>
            </li>
          ))}
        </ul>

        <div class="card-timeline">
          <svg class="timeline-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1" />
            <path d="M8 4.5V8L10.5 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
          </svg>
          <span>Laufzeit: 8–12 Wochen</span>
        </div>

        <a
          href="#kontakt"
          class="card-cta"
          onclick="window.posthog?.capture('erstgespraech_cta_clicked', { source: 'pricing_phase1' })"
        >
          Erstgespräch buchen
        </a>
      </div>

      <!-- Card 2: From 1 to X (Highlighted) -->
      <div class="pricing-card pricing-card--highlighted reveal-on-scroll lg:w-1/2">
        <!-- Badge -->
        <span class="card-badge">Empfohlen</span>

        <div class="card-header">
          <h3 class="card-title">From 1 to X</h3>
          <span class="card-subtitle">Der Loop</span>
        </div>

        <div class="card-price-area">
          <span class="card-price">Auf Anfrage</span>
          <span class="card-price-suffix">/Monat</span>
        </div>

        <div class="card-divider"></div>

        <ul class="card-features">
          {phase2Features.map((feature) => (
            <li class="card-feature">
              <svg class="feature-check" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 10.5L8.5 14L15 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{feature.text}</span>
            </li>
          ))}
        </ul>

        <div class="card-timeline">
          <svg class="timeline-icon" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1" />
            <path d="M8 4.5V8L10.5 10" stroke="currentColor" stroke-width="1" stroke-linecap="round" />
          </svg>
          <span>Laufzeit: 12 Monate (empfohlen)</span>
        </div>

        <a
          href="#kontakt"
          class="card-cta"
          onclick="window.posthog?.capture('erstgespraech_cta_clicked', { source: 'pricing_phase2' })"
        >
          Erstgespräch buchen
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Pricing Card ---- */
  .pricing-card {
    background: var(--color-white);
    border: 1px solid rgba(26, 26, 26, 0.08);
    border-radius: var(--radius-lg);
    padding: clamp(32px, 4vw, 48px);
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .pricing-card--highlighted {
    border-color: var(--color-ultraviolett);
    box-shadow: 0 0 40px var(--color-uv-glow), 0 0 80px rgba(36, 0, 229, 0.06);
  }

  /* Badge */
  .card-badge {
    position: absolute;
    top: -12px;
    left: clamp(32px, 4vw, 48px);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-white);
    background: var(--color-ultraviolett);
    padding: 4px 12px;
    border-radius: var(--radius-sm);
  }

  /* Header */
  .card-header {
    margin-bottom: 24px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(1.375rem, 2vw + 0.25rem, 1.75rem);
    color: var(--color-ink);
    line-height: 1.2;
    margin-bottom: 4px;
  }

  .card-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-light);
  }

  /* Price */
  .card-price-area {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 24px;
  }

  .card-price {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem);
    font-weight: 700;
    color: var(--color-ink);
    line-height: 1;
  }

  .card-price-suffix {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-light);
  }

  /* Divider */
  .card-divider {
    height: 1px;
    background: rgba(26, 26, 26, 0.08);
    margin-bottom: 24px;
  }

  /* Features */
  .card-features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .card-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: clamp(0.875rem, 0.5vw + 0.5rem, 1rem);
    color: var(--color-ink);
    line-height: 1.5;
  }

  .feature-check {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--color-ultraviolett);
    margin-top: 1px;
  }

  /* Timeline */
  .card-timeline {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-ink-light);
    margin-bottom: 28px;
    padding: 12px 0;
    border-top: 1px solid rgba(26, 26, 26, 0.06);
  }

  .timeline-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: var(--color-ink-light);
  }

  /* CTA Button */
  .card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 24px;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-sand);
    background: var(--color-ultraviolett);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: transform var(--duration-fast) var(--ease-default),
                box-shadow var(--duration-fast) var(--ease-default);
  }

  .card-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px var(--color-uv-glow);
  }

  /* Highlighted card CTA emphasis */
  .pricing-card--highlighted .card-cta {
    box-shadow: 0 2px 12px var(--color-uv-glow);
  }
</style>
