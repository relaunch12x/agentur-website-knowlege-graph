---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Vielen Dank — Relaunch12x"
  description="Ihre Nachricht ist angekommen. Wir melden uns innerhalb von 24 Stunden."
>
  <Nav currentPath="/danke" />

  <section
    class="section-dark grain-overlay relative overflow-hidden"
    style="min-height: 100vh; display: flex; align-items: center; justify-content: center;"
  >
    <!-- Dot Grid Background -->
    <div class="dot-grid absolute inset-0 -z-10"></div>

    <!-- UV Glow -->
    <div
      class="absolute top-1/3 left-1/2 -translate-x-1/2 -z-10"
      style="width: 600px; height: 600px; background: radial-gradient(circle, rgba(36, 0, 229, 0.15) 0%, transparent 70%); filter: blur(80px);"
      aria-hidden="true"
    ></div>

    <div class="container-content relative z-10 flex flex-col items-center text-center" style="padding-block: 160px;">
      <!-- Checkmark -->
      <div
        class="mb-8"
        style="width: 72px; height: 72px; display: flex; align-items: center; justify-content: center; background: rgba(36, 0, 229, 0.12); border-radius: 50%; border: 1px solid rgba(36, 0, 229, 0.2);"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-ultraviolett-text)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <span class="section-label mb-6">Geschafft</span>

      <h1
        class="mb-6"
        style="font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem); color: var(--color-sand);"
      >
        Nachricht <em style="color: var(--color-ultraviolett-text); font-style: italic;">angekommen</em>.
      </h1>

      <p
        class="mb-12 max-w-lg"
        style="color: rgba(245, 240, 232, 0.6); line-height: 1.7; font-size: 1.0625rem;"
      >
        Wir melden uns innerhalb von 24 Stunden bei Ihnen — per E-Mail, mit einem Terminvorschlag für Ihr kostenloses Erstgespräch.
      </p>

      <a
        href="/"
        class="inline-block rounded-lg px-8 py-3.5 text-sm font-medium transition-all duration-300 hover:-translate-y-0.5"
        style="background: rgba(245, 240, 232, 0.06); border: 1px solid rgba(245, 240, 232, 0.12); color: var(--color-sand);"
        onmouseover="this.style.borderColor='var(--color-ultraviolett)'"
        onmouseout="this.style.borderColor='rgba(245, 240, 232, 0.12)'"
      >
        Zurück zur Startseite
      </a>

      <p
        class="mt-6"
        style="font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.05em; color: rgba(245, 240, 232, 0.35);"
      >
        Keine automatische Bestätigungs-E-Mail. Echte Menschen, echte Antworten.
      </p>
    </div>
  </section>

  <Footer />
</BaseLayout>
